# Secrets documentation:
# https://validatedpatterns.io/learn/secrets-management-in-the-validated-patterns-framework/
#
# IMPORTANT: Copy this file to values-secret.yaml and configure before installation.
# DO NOT commit values-secret.yaml to git.
version: "2.0"

secrets:
  # Demo secret for config-demo application (safe to auto-generate)
  - name: config-demo
    vaultPrefixes:
      - global
    fields:
      - name: secret
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy

  # Kairos AI credentials (legacy RHDP: kairos-system/kairos-ai-credentials)
  # For production: set onMissingValue: error and provide manually
  - name: kairos-ai-credentials
    vaultPrefixes:
      - global
    fields:
      - name: api-key
        onMissingValue: generate  # Change to 'error' in production
        vaultPolicy: validatedPatternDefaultPolicy

  # OpenShift AI / MaaS workshop credentials
  # For production: set onMissingValue: error and provide real API keys
  - name: openshift-ai-maas-credentials
    vaultPrefixes:
      - global
    fields:
      - name: OPENAI_API_KEY
        onMissingValue: generate  # Change to 'error' in production
        vaultPolicy: validatedPatternDefaultPolicy
      - name: OPENAI_API_BASE
        onMissingValue: generate  # Change to 'error' in production
        vaultPolicy: validatedPatternDefaultPolicy

  # MCP Gateway Argo CD token
  # WARNING: Auto-generated tokens cannot be revoked without Vault rotation.
  # For production: create token manually via ArgoCD CLI and use path below:
  #   argocd account generate-token --account mcp-gateway > ~/.mcp-gateway-token
  - name: mcp-gateway-argocd
    vaultPrefixes:
      - global
    fields:
      - name: token
        onMissingValue: generate  # Demo only - for production use path below
        vaultPolicy: validatedPatternDefaultPolicy
        # Production: uncomment path and set onMissingValue: error
        # onMissingValue: error
        # path: ~/.mcp-gateway-token

  # Workshop demo password — use OAuth in production; demo only
  - name: workshop-users
    vaultPrefixes:
      - global
    fields:
      - name: defaultPassword
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy

  #############################################################################
  # CLUSTER PROVISIONING (ACM ClusterPools)
  # IMPORTANT: These secrets are REQUIRED for provisioning new clusters via ACM.
  # Without them, cluster provisioning will fail silently.
  # Uncomment and configure for production deployments.
  #############################################################################

  # AWS credentials for cluster provisioning
