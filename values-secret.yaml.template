# Secrets documentation:
# https://validatedpatterns.io/learn/secrets-management-in-the-validated-patterns-framework/
version: "2.0"

secrets:
  - name: config-demo
    vaultPrefixes:
      - global
    fields:
      - name: secret
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy

  # Kairos AI credentials (legacy RHDP: kairos-system/kairos-ai-credentials)
  - name: kairos-ai-credentials
    vaultPrefixes:
      - global
    fields:
      - name: api-key
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy

  # OpenShift AI / MaaS workshop credentials
  - name: openshift-ai-maas-credentials
    vaultPrefixes:
      - global
    fields:
      - name: OPENAI_API_KEY
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy
      - name: OPENAI_API_BASE
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy

  # MCP Gateway Argo CD token (optional)
  - name: mcp-gateway-argocd
    vaultPrefixes:
      - global
    fields:
      - name: token
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy

  # Workshop demo password — use OAuth in production; demo only
  - name: workshop-users
    vaultPrefixes:
      - global
    fields:
      - name: defaultPassword
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy

